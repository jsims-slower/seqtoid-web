<%= javascript_tag do %>
  react_component("UserStorageConsumptionDashboard", {
    users: JSON.parse('<%= raw escape_json(@users_data) %>'),
    page: JSON.parse('<%= raw escape_json(@page) %>'),
    perPage: JSON.parse('<%= raw escape_json(@per_page) %>'),
    totalCount: JSON.parse('<%= raw escape_json(@total_count) %>'),
    searchBy: JSON.parse('<%= raw escape_json(@search_by) %>'),
    sortBy: JSON.parse('<%= raw escape_json(@sort_by) %>'),
    sortDir: JSON.parse('<%= raw escape_json(@sort_dir) %>'),
    totalUsers: JSON.parse('<%= raw escape_json(@total_users) %>'),
    totalSamples: JSON.parse('<%= raw escape_json(@total_samples) %>'),
    totalInputFiles: JSON.parse('<%= raw escape_json(@total_input_files) %>'),
    totalInputFilesSize: JSON.parse('<%= raw escape_json(@total_input_files_size) %>'),
    averageFileSize: JSON.parse('<%= raw escape_json(@average_file_size) %>'),
    averageFilesPerUser: JSON.parse('<%= raw escape_json(@average_files_per_user) %>'),
    flaggedFilesCount: JSON.parse('<%= raw escape_json(@flagged_files_count) %>'),
    snapshotData: JSON.parse('<%= raw escape_json(@snapshot_data) %>')
  }, 'page_content');
<% end %>
