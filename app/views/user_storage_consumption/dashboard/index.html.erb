<%= javascript_tag do %>
  react_component("UserStorageConsumptionDashboard", {
    totalUsers: JSON.parse('<%= raw escape_json(@total_users) %>'),
    totalSamples: JSON.parse('<%= raw escape_json(@total_samples) %>'),
    totalInputFiles: JSON.parse('<%= raw escape_json(@total_input_files) %>'),
    totalInputFilesSize: JSON.parse('<%= raw escape_json(@total_input_files_size) %>'),
    totalSampleS3Files: JSON.parse('<%= raw escape_json(@total_sample_s3_files) %>'),
    totalSampleS3StorageSize: JSON.parse('<%= raw escape_json(@total_sample_s3_storage_size) %>'),
    flaggedFilesCount: JSON.parse('<%= raw escape_json(@flagged_files_count) %>'),
    snapshotData: JSON.parse('<%= raw escape_json(@snapshot_data) %>')
  }, 'page_content');
<% end %>
