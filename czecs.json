{
  "family": "{{ .Values.project }}-dev-{{ .Values.name }}",
  "containerDefinitions": [
    {
      "name": "rails",
      "image": "{{ .Values.account_id }}.dkr.ecr.{{ .Values.region }}.amazonaws.com/idseq-web:{{ .Values.tag }}",
      "cpu": 1024,
      "memoryReservation": 2000,
      "memory": 4096,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 0
        }
      ],
      "environment": [
        {
          "name": "RAILS_ENV",
          "value": "development"
        },
        {
          "name": "ENVIRONMENT",
          "value": "dev"
        },
        {
          "name": "RAILS_LOG_TO_STDOUT",
          "value": "yes"
        },
        {
          "name": "AWS_REGION",
          "value": "{{ .Values.region }}"
        },
        {
          "name": "AWS_DEFAULT_REGION",
          "value": "{{ .Values.region }}"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "ecs-logs-dev",
          "awslogs-region": "{{ .Values.region }}",
          "awslogs-stream-prefix": "rails"
        }
      }
    }
  ],
  "taskRoleArn": "{{ .Values.project }}-web-dev"
}
